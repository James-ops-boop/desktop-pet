{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shadow Companion",
  "version": "0.1.0",
  "identifier": "io.github.jamesopsboop.shadow-companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "Shadow Companion",
        "url": "index.html",
        "width": 380,
        "height": 380,
        "center": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "visible": true
      },
      {
        "label": "settings",
        "title": "Shadow Companion 设置",
        "url": "index.html",
        "width": 920,
        "height": 640,
        "minWidth": 640,
        "minHeight": 460,
        "center": true,
        "transparent": false,
        "decorations": true,
        "skipTaskbar": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["pet", "settings"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
