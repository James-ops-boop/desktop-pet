{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "pet",
  "description": "Desktop pet window access for drag, position restore and settings persistence",
  "windows": ["pet"],
  "platforms": ["windows"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-position",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save"
  ]
}
